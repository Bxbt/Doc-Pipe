// Project Document Pipeline — data model
// SQLite has no native enums, so enum-like fields are stored as strings
// and validated in application code (see src/lib/constants.ts).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Runtime connection (pgBouncer/pooler in prod). directUrl is the direct
  // connection used for migrations / `prisma db push`.
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  // Role: Admin | Editor | Reviewer | Viewer
  role      String   @default("Viewer")
  createdAt DateTime @default(now())

  documentsEdited Document[]      @relation("DocumentUpdatedBy")
  memberships     ProjectMember[]
  comments        Comment[]
  threadsCreated  CommentThread[] @relation("ThreadCreatedBy")
  threadsResolved CommentThread[] @relation("ThreadResolvedBy")
  activities      Activity[]
  versions        DocumentVersion[]
  attachments     Attachment[]
  accessTokens    PersonalAccessToken[]
}

// A personal access token lets an external client (e.g. a local MCP bridge
// running beside the user's Claude/ChatGPT) act as this user over the API.
// Only the SHA-256 hash is stored; the raw token is shown once at creation.
model PersonalAccessToken {
  id         String    @id @default(cuid())
  userId     String
  name       String
  tokenHash  String    @unique
  // Non-secret display hint, e.g. "dp_ab12…f9" — safe to store and show.
  preview    String
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Project {
  id          String   @id @default(cuid())
  name        String
  // Optional base name for exported files ({exportName}_YYMMDD.docx). Lets a
  // Thai-named project get a clean ASCII filename; empty falls back to name.
  exportName  String?
  customer    String?
  // Drives the Smart Checklist of recommended documents.
  businessType String  @default("Generic")
  status      String   @default("Active") // Active | OnHold | Done | Archived
  // Who can SEE the project. "public" = every authenticated user; "private" =
  // only members (ProjectMember) + Admins. CRUD is still gated by global role.
  visibility  String   @default("public") // public | private
  description String?
  // Manually-entered document revision history for the Word export's front table.
  // JSON string: {editor,date,detail,version,approver}[] (date = "YYYY-MM-DD").
  revisionHistory String @default("[]")
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  documents    Document[]
  dependencies DocumentDependency[]
  members      ProjectMember[]
  activities   Activity[]
}

model ProjectMember {
  id        String  @id @default(cuid())
  projectId String
  userId    String
  // "owner" (the creator; may share/toggle visibility) or "member" (granted access).
  role      String  @default("member")
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
}

model Document {
  id        String   @id @default(cuid())
  projectId String
  // One of the DOC_TYPES (see constants.ts): BUSINESS_REQUIREMENT, SRS, ...
  type      String
  title     String
  // Draft | InReview | Approved | Outdated
  status    String   @default("Draft")
  content   String   @default("")
  version   String   @default("v1.0")
  // Set true when an upstream document changed after this one was last touched.
  outdated  Boolean  @default(false)
  // Manual position in the project pipeline (lower = earlier).
  order     Int      @default(0)
  // Manual node coordinates on the dependency graph (null = auto-layout).
  gx        Int?
  gy        Int?

  // Pessimistic edit lock: who currently has the editor open. `editingAt` is
  // refreshed by a heartbeat; a lock older than the TTL is treated as stale and
  // can be taken over (see acquireEditLock in src/lib/actions.ts).
  editingById   String?
  editingByName String?
  editingAt     DateTime?

  updatedById String?
  updatedBy   User?   @relation("DocumentUpdatedBy", fields: [updatedById], references: [id])
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // Edges where this document is the upstream source (it affects others).
  outgoing DocumentDependency[] @relation("SourceDoc")
  // Edges where this document depends on an upstream source.
  incoming DocumentDependency[] @relation("TargetDoc")

  threads  CommentThread[]
  versions DocumentVersion[]
  attachments Attachment[]
  activities Activity[]

  @@index([projectId])
}

// Files attached to a document. Binary lives on disk (see src/lib/storage.ts);
// only metadata is stored here.
model Attachment {
  id           String   @id @default(cuid())
  documentId   String
  filename     String
  mime         String
  size         Int
  storedName   String
  uploadedById String?
  createdAt    DateTime @default(now())

  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  uploadedBy User?    @relation(fields: [uploadedById], references: [id])

  @@index([documentId])
}

// Directed edge: `target` depends on `source`.
// When `source` changes, `target` becomes outdated.
model DocumentDependency {
  id        String @id @default(cuid())
  projectId String
  sourceId  String
  targetId  String

  project Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  source  Document @relation("SourceDoc", fields: [sourceId], references: [id], onDelete: Cascade)
  target  Document @relation("TargetDoc", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([sourceId, targetId])
  // sourceId is already covered by the unique index prefix; index targetId for
  // upstream lookups and projectId for per-project graph loads.
  @@index([targetId])
  @@index([projectId])
}

model DocumentVersion {
  id         String   @id @default(cuid())
  documentId String
  version    String
  content    String
  note       String?
  createdAt  DateTime @default(now())
  authorId   String?

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  author   User?    @relation(fields: [authorId], references: [id])

  @@index([documentId])
}

// A comment thread on a document. Doc-level when anchorBlock is null; otherwise
// it is anchored to a content block (a section/paragraph) in the read view.
model CommentThread {
  id         String   @id @default(cuid())
  documentId String
  // Index of the anchored top-level block in the rendered content, and a short
  // text snippet of it. The snippet re-anchors the thread if blocks shift; a
  // thread that matches neither is shown in the panel as "orphaned".
  anchorBlock Int?
  anchorQuote String?
  resolved    Boolean  @default(false)
  resolvedById String?
  resolvedAt   DateTime?
  createdById  String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  createdBy  User     @relation("ThreadCreatedBy", fields: [createdById], references: [id])
  resolvedBy User?    @relation("ThreadResolvedBy", fields: [resolvedById], references: [id])
  comments   Comment[]

  @@index([documentId])
}

model Comment {
  id        String   @id @default(cuid())
  threadId  String
  authorId  String
  body      String
  editedAt  DateTime?
  createdAt DateTime @default(now())

  thread CommentThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  author User          @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([threadId])
}

model Template {
  id          String   @id @default(cuid())
  name        String
  description String   @default("")
  content     String   @default("")
  builtin     Boolean  @default(false)
  sort        Int      @default(0)
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())
}

// A business type and its editable "generate pipeline" definition.
// docTypes/edges are JSON strings (SQLite has no native arrays).
model BusinessType {
  id        String   @id @default(cuid())
  name      String   @unique
  sort      Int      @default(0)
  docTypes  String   @default("[]") // JSON: DocType[]
  edges     String   @default("[]") // JSON: [from, to][]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Activity {
  id        String   @id @default(cuid())
  projectId String?
  // The document this activity is about, when it concerns a single document
  // (edited, added, status change, link target…). Null for project-level events.
  documentId String?
  userId    String?
  // Free-form action label, e.g. "marked_changed", "edited", "approved"
  action    String
  detail    String?
  createdAt DateTime @default(now())

  // Keep the audit trail even after a project is deleted (projectId becomes null).
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  // Likewise survive document deletion — the link just drops to the project.
  document Document? @relation(fields: [documentId], references: [id], onDelete: SetNull)
  user    User?    @relation(fields: [userId], references: [id])

  @@index([projectId])
  @@index([createdAt])
}
