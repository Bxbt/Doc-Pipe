// SOURCE schema for the one-shot SQLite → Postgres migration ONLY.
// Mirrors schema.prisma's models but with the sqlite provider, so the copy
// script (prisma/sqlite-to-pg.ts) can read the old DB with a second client.
// Generates to src/generated/sqlite-client (gitignored). Delete both this file
// and that client once the migration is done.

generator sqliteClient {
  provider = "prisma-client-js"
  output   = "../src/generated/sqlite-client"
}

datasource db {
  provider = "sqlite"
  url      = env("SQLITE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  role      String   @default("Viewer")
  createdAt DateTime @default(now())

  documentsEdited Document[]      @relation("DocumentUpdatedBy")
  memberships     ProjectMember[]
  comments        Comment[]
  threadsCreated  CommentThread[] @relation("ThreadCreatedBy")
  threadsResolved CommentThread[] @relation("ThreadResolvedBy")
  activities      Activity[]
  versions        DocumentVersion[]
  attachments     Attachment[]
  accessTokens    PersonalAccessToken[]
}

model PersonalAccessToken {
  id         String    @id @default(cuid())
  userId     String
  name       String
  tokenHash  String    @unique
  preview    String
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Project {
  id          String   @id @default(cuid())
  name        String
  exportName  String?
  customer    String?
  businessType String  @default("Generic")
  status      String   @default("Active")
  description String?
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  documents    Document[]
  dependencies DocumentDependency[]
  members      ProjectMember[]
  activities   Activity[]
}

model ProjectMember {
  id        String  @id @default(cuid())
  projectId String
  userId    String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
}

model Document {
  id        String   @id @default(cuid())
  projectId String
  type      String
  title     String
  status    String   @default("Draft")
  content   String   @default("")
  version   String   @default("v1.0")
  outdated  Boolean  @default(false)
  order     Int      @default(0)
  gx        Int?
  gy        Int?

  editingById   String?
  editingByName String?
  editingAt     DateTime?

  updatedById String?
  updatedBy   User?   @relation("DocumentUpdatedBy", fields: [updatedById], references: [id])
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  outgoing DocumentDependency[] @relation("SourceDoc")
  incoming DocumentDependency[] @relation("TargetDoc")

  threads  CommentThread[]
  versions DocumentVersion[]
  attachments Attachment[]
  activities Activity[]

  @@index([projectId])
}

model Attachment {
  id           String   @id @default(cuid())
  documentId   String
  filename     String
  mime         String
  size         Int
  storedName   String
  uploadedById String?
  createdAt    DateTime @default(now())

  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  uploadedBy User?    @relation(fields: [uploadedById], references: [id])

  @@index([documentId])
}

model DocumentDependency {
  id        String @id @default(cuid())
  projectId String
  sourceId  String
  targetId  String

  project Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  source  Document @relation("SourceDoc", fields: [sourceId], references: [id], onDelete: Cascade)
  target  Document @relation("TargetDoc", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([sourceId, targetId])
  @@index([targetId])
  @@index([projectId])
}

model DocumentVersion {
  id         String   @id @default(cuid())
  documentId String
  version    String
  content    String
  note       String?
  createdAt  DateTime @default(now())
  authorId   String?

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  author   User?    @relation(fields: [authorId], references: [id])

  @@index([documentId])
}

model CommentThread {
  id         String   @id @default(cuid())
  documentId String
  anchorBlock Int?
  anchorQuote String?
  resolved    Boolean  @default(false)
  resolvedById String?
  resolvedAt   DateTime?
  createdById  String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  createdBy  User     @relation("ThreadCreatedBy", fields: [createdById], references: [id])
  resolvedBy User?    @relation("ThreadResolvedBy", fields: [resolvedById], references: [id])
  comments   Comment[]

  @@index([documentId])
}

model Comment {
  id        String   @id @default(cuid())
  threadId  String
  authorId  String
  body      String
  editedAt  DateTime?
  createdAt DateTime @default(now())

  thread CommentThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  author User          @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([threadId])
}

model Template {
  id          String   @id @default(cuid())
  name        String
  description String   @default("")
  content     String   @default("")
  builtin     Boolean  @default(false)
  sort        Int      @default(0)
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())
}

model BusinessType {
  id        String   @id @default(cuid())
  name      String   @unique
  sort      Int      @default(0)
  docTypes  String   @default("[]")
  edges     String   @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Activity {
  id        String   @id @default(cuid())
  projectId String?
  documentId String?
  userId    String?
  action    String
  detail    String?
  createdAt DateTime @default(now())

  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  document Document? @relation(fields: [documentId], references: [id], onDelete: SetNull)
  user    User?    @relation(fields: [userId], references: [id])

  @@index([projectId])
  @@index([createdAt])
}
