# Postgres connection. DIRECT_URL is used by `prisma db push`/migrations;
# both can be the same instance for a self-hosted single Postgres.
DATABASE_URL="postgresql://docpipe:CHANGE_ME@localhost:5432/docpipe"
DIRECT_URL="postgresql://docpipe:CHANGE_ME@localhost:5432/docpipe"

# Postgres container password (docker-compose reads this)
POSTGRES_PASSWORD="CHANGE_ME"

# Persistent data volume (uploads + seed marker). Prod: /data
DATA_DIR="./data"
UPLOAD_DIR="./data/uploads"

# Local development identity (ignored in production behind Cloudflare Access)
DEV_EMAIL="admin@example.com"

# Bootstrap admins — always treated as Admin
ADMIN_EMAILS="you@example.com"

# One-shot SQLite -> Postgres migration: path to the old SQLite DB
# SQLITE_URL="file:./prisma/dev.db"
